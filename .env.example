# ==========================================
# GCP Environment Configuration
# ==========================================
PROJECT_ID=your-gcp-project-id
LOCATION=gcp-project-location  #(i.e australia-southeast1)

# ==========================================
# AI Model Configuration
# ==========================================
GEMINI_MODEL_NAME=gemini-2.5-flash
REVIEWER_MODEL_NAME=llama-3.3-70b-versatile

# ==========================================
# Secrets & API Keys (LOCAL DEV ONLY)
# ==========================================
# PRODUCTION NOTE: Do not deploy an .env file to production!
# In production, these are injected directly into Cloud Run via:
# --set-secrets="API_KEY=customermind-api-key:latest,GROQ_API_KEY=groq-api-key:latest"

API_KEY=your_local_dev_api_key
GROQ_API_KEY=gsk_your_local_groq_api_key

# ==========================================
# Microservice Internal Routing
# ==========================================
# Note: For local development using Docker Compose, use http://host.docker.internal:PORT 
# For production, replace these with your deployed Cloud Run URLs (https://...run.app)

URL_MODELER=http://localhost:8001/api/v1/predict
URL_PROFILER=http://localhost:8002/api/v1/profile
URL_STRATEGIST=http://localhost:8003/api/v1/strategize
URL_REVIEWER=http://localhost:8004/api/v1/review
URL_ANALYTICS=http://localhost:8001/api/v1/cohort-analytics
URL_ORCHESTRATOR=http://localhost:8000